<Window x:Class="Moongate.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L.Onboarding.Title}"
        Width="440" Height="360" MinWidth="420" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Border Padding="24">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="{DynamicResource L.Onboarding.Start}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="104"
                        Click="OnStartClick"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="{DynamicResource L.Onboarding.Title}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBlock Text="{DynamicResource L.Onboarding.Subtitle}"
                           Style="{StaticResource Caption}"
                           FontSize="12.5"
                           Margin="0,0,0,18"/>

                <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource L.Onboarding.AppLanguage}"
                                       Width="112"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="AppLanguageBox" SelectedIndex="0">
                                <ComboBoxItem Content="{DynamicResource L.Settings.LangAuto}"/>
                                <ComboBoxItem Content="简体中文"/>
                                <ComboBoxItem Content="繁體中文"/>
                                <ComboBoxItem Content="English"/>
                            </ComboBox>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="{DynamicResource L.Onboarding.TargetLanguage}"
                                       Width="112"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="TargetLanguageBox" SelectedIndex="0">
                                <ComboBoxItem Content="简体中文"/>
                                <ComboBoxItem Content="繁體中文"/>
                                <ComboBoxItem Content="English"/>
                            </ComboBox>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{DynamicResource L.Onboarding.AIOptional}"
                           Style="{StaticResource Caption}"/>
                <TextBlock x:Name="ErrorText"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
