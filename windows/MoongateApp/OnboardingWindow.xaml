<Window x:Class="Moongate.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L.Onboarding.Title}"
        Width="560" Height="592" MinWidth="520" MinHeight="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Border Padding="24">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button x:Name="BackButton"
                        Content="{DynamicResource L.Onboarding.Back}"
                        MinWidth="92"
                        Margin="0,0,8,0"
                        Click="OnBackClick"/>
                <Button x:Name="NextButton"
                        Content="{DynamicResource L.Onboarding.Next}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="92"
                        Click="OnNextClick"/>
                <Button x:Name="StartButton"
                        Content="{DynamicResource L.Onboarding.Start}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="104"
                        Visibility="Collapsed"
                        Click="OnStartClick"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="{DynamicResource L.Onboarding.Title}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBlock Text="{DynamicResource L.Onboarding.Subtitle}"
                           Style="{StaticResource Caption}"
                           FontSize="12.5"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <UniformGrid Columns="4" Margin="0,0,0,14">
                    <TextBlock x:Name="LanguageStepLabel"
                               Text="{DynamicResource L.Onboarding.LanguageStep}"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="SubtitleSourceStepLabel"
                               Text="{DynamicResource L.Onboarding.SubtitleSourceStep}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="TranslationMethodStepLabel"
                               Text="{DynamicResource L.Onboarding.TranslationMethodStep}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="ReadinessStepLabel"
                               Text="{DynamicResource L.Onboarding.ReadinessStep}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </UniformGrid>

                <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12" MinHeight="238">
                    <Grid>
                        <StackPanel x:Name="LanguagePanel">
                            <TextBlock Text="{DynamicResource L.Onboarding.LanguageStep}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,14"/>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource L.Onboarding.AppLanguage}"
                                           Width="132"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="AppLanguageBox" SelectedIndex="0" AutomationProperties.Name="{DynamicResource L.Onboarding.AppLanguage}">
                                    <ComboBoxItem Content="{DynamicResource L.Settings.LangAuto}"/>
                                    <ComboBoxItem Content="简体中文"/>
                                    <ComboBoxItem Content="繁體中文"/>
                                    <ComboBoxItem Content="English"/>
                                </ComboBox>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="{DynamicResource L.Onboarding.TargetLanguage}"
                                           Width="132"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="TargetLanguageBox" SelectedIndex="0" AutomationProperties.Name="{DynamicResource L.Onboarding.TargetLanguage}">
                                    <ComboBoxItem Content="简体中文"/>
                                    <ComboBoxItem Content="繁體中文"/>
                                    <ComboBoxItem Content="English"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>

                        <StackPanel x:Name="SubtitleSourcePanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource L.Onboarding.SubtitleSourceStep}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{DynamicResource L.Onboarding.PlatformSubtitlePreference}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>
                            <CheckBox x:Name="PreferLocalSpeechRecognitionBox"
                                      Content="{DynamicResource L.Onboarding.PreferLocalSpeechRecognition}"
                                      Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource L.Onboarding.LocalSpeechSetupLater}"
                                       Style="{StaticResource Caption}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel x:Name="TranslationMethodPanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource L.Onboarding.TranslationMethodStep}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource L.Onboarding.TranslationProvider}"
                                           Width="92"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="TranslationProviderBox" SelectedIndex="{Binding ProviderIndex, Mode=TwoWay}" AutomationProperties.Name="{DynamicResource L.Onboarding.TranslationProvider}">
                                    <ComboBoxItem Content="Anthropic-compatible"/>
                                    <ComboBoxItem Content="OpenAI-compatible"/>
                                </ComboBox>
                            </DockPanel>
                            <TextBlock Text="{DynamicResource L.Onboarding.AIOptional}"
                                       Style="{StaticResource Caption}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="156">
                                <StackPanel Margin="0,0,4,0">
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="{DynamicResource L.Settings.BaseUrl}" Width="92" VerticalAlignment="Center"/>
                                        <TextBox Padding="6,4" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="{DynamicResource L.Settings.BaseUrl}"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="{DynamicResource L.Settings.Credential}" Width="92" VerticalAlignment="Center"/>
                                        <PasswordBox x:Name="OnboardingApiTokenBox" Padding="6,4" PasswordChanged="OnApiTokenChanged" AutomationProperties.Name="{DynamicResource L.Settings.Credential}"/>
                                    </DockPanel>
                                    <DockPanel Margin="92,0,0,8">
                                        <Button DockPanel.Dock="Left" Content="{DynamicResource L.Settings.FetchModels}"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding Endpoint.FetchModelsCommand}"/>
                                        <TextBlock Text="{Binding Endpoint.FetchStatusText}" FontSize="11.5" Margin="10,0,0,0"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"
                                                   Visibility="{Binding Endpoint.FetchStatusText, Converter={StaticResource TextToVis}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Endpoint.FetchStatusIsError}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,8"
                                               Visibility="{Binding Endpoint.ShowModelPicker, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{DynamicResource L.Settings.SelectModel}" Width="92" VerticalAlignment="Center"/>
                                        <ComboBox ItemsSource="{Binding Endpoint.ModelOptions}"
                                                  SelectedItem="{Binding Endpoint.SelectedModelOption}"
                                                  AutomationProperties.Name="{DynamicResource L.Settings.SelectModel}"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="{DynamicResource L.Settings.ModelName}" Width="92" VerticalAlignment="Center"/>
                                        <TextBox Padding="6,4" Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="{DynamicResource L.Settings.ModelName}"/>
                                    </DockPanel>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Left" Content="{DynamicResource L.Settings.TestConnection}"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding Endpoint.TestConnectionCommand}"/>
                                        <TextBlock Text="{Binding Endpoint.TestStatusText}" FontSize="11.5" Margin="10,0,0,0"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"
                                                   Visibility="{Binding Endpoint.TestStatusText, Converter={StaticResource TextToVis}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Endpoint.TestStatusIsError}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Endpoint.TestStatusIsSuccess}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DockPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>

                        <StackPanel x:Name="ReadinessPanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource L.Onboarding.ReadinessSummary}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,14"/>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource L.Onboarding.AppLanguage}"
                                           Width="132"/>
                                <TextBlock x:Name="SummaryAppLanguage"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource L.Onboarding.TargetLanguage}"
                                           Width="132"/>
                                <TextBlock x:Name="SummaryTargetLanguage"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource L.Onboarding.TranslationMethodStep}"
                                           Width="132"/>
                                <TextBlock x:Name="SummaryTranslationMethod"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="{DynamicResource L.Onboarding.SubtitleSourceStep}"
                                           Width="132"/>
                                <TextBlock x:Name="SummarySubtitleSource"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <TextBlock x:Name="ErrorText"
                           Foreground="{DynamicResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
